    function library:ToggleGUI(yesno)
        self.visible = (yesno == nil) and (not self.visible) or yesno
        if self.visible then self:_ShowGUI() else self:_HideGUI() end
        return self.visible
    end

    function library:_ShowGUI() self.MasterContainer:TweenSize(self.size, "Out", "Quad", 0.2, true) end
    function library:_HideGUI() self.MasterContainer:TweenSize(UDim2.new(0, self.size.X.Offset, 0, 0), "In", "Quad", 0.2, true) end

    function library:SetKeybind(new) self.keybind = new return self.keybind end

    function library:_registerKeybind()
        local debounce = false
        table.insert(self._connections, input.InputBegan:Connect(function(inp, gpe)
            if inp.UserInputType == Enum.UserInputType.Keyboard and not gpe and inp.KeyCode == self.keybind and not debounce then
                debounce = true
                self:ToggleGUI()
                task.wait(0.2)
                debounce = false
            end
        end))
        return self
    end
end


        local btn = create("TextButton", {
            Parent = tabList,
            BackgroundColor3 = colorScheme.Button,
            Text = name,
            TextColor3 = colorScheme.Text,
            TextSize = 14,
            Font = Enum.Font.Gotham,
            Size = UDim2.new(1, -10, 0, 30),
            AutoButtonColor = false
        })
        create("UICorner", {CornerRadius = UDim.new(0, 4)})().Parent = btn

        -- Анимация наведения
        btn.MouseEnter:Connect(function()
            tween(btn, {BackgroundColor3 = colorScheme.ButtonHover}, 0.2)
        end)
        btn.MouseLeave:Connect(function()
            if activeTab ~= tab then
                tween(btn, {BackgroundColor3 = colorScheme.Button}, 0.2)
            end
        end)

        btn.MouseButton1Click:Connect(function()
            if activeTab then
                tween(activeTab.buttons[1], {BackgroundColor3 = colorScheme.Button}, 0.2)
            end
            activeTab = tab
            tween(btn, {BackgroundColor3 = colorScheme.Accent}, 0.2)
            updateSubtabList(tab)
        end)

        tab.buttons[1] = btn
        return tab
    end

    -- Метод для создания подтаба
    local function createSubtab(tab, name)
        local subtab = {
            name = name,
            sections = {}, -- таблица секций {column = номер, name = название, elements = {}}
            currentColumn = 1,
            currentSection = nil
        }

        function subtab:AddColumn(columnNumber)
            self.currentColumn = columnNumber
        end

        function subtab:AddSection(name)
            self.currentSection = name
            table.insert(self.sections, {column = self.currentColumn, name = name, elements = {}})
        end

        function subtab:AddToggle(config)
            -- config: {name = "Toggle", default = false, callback = function(val)}
            table.insert(self.sections[#self.sections].elements, {type = "toggle", config = config})
        end

        function subtab:AddSlider(config)
            -- config: {name = "Slider", min = 0, max = 100, default = 50, callback = function(val)}
            table.insert(self.sections[#self.sections].elements, {type = "slider", config = config})
        end

        function subtab:AddDropdown(config)
            -- config: {name = "Dropdown", options = {"Opt1", "Opt2"}, default = "Opt1", callback = function(opt)}
            table.insert(self.sections[#self.sections].elements, {type = "dropdown", config = config})
        end

        function subtab:AddButton(config)
            -- config: {name = "Button", callback = function()}
            table.insert(self.sections[#self.sections].elements, {type = "button", config = config})
        end

        function subtab:Render(parentFrame)
            -- Очистить parentFrame
            for _, child in ipairs(parentFrame:GetChildren()) do
                if child:IsA("Frame") or child:IsA("ScrollingFrame") then
                    child:Destroy()
                end
            end

            -- Создать колонки
            local columns = {}
            for i = 1, 2 do
                local col = create("ScrollingFrame", {
                    Parent = parentFrame,
                    BackgroundTransparency = 1,
                    BorderSizePixel = 0,
                    Size = UDim2.new(0.5, -5, 1, 0),
                    CanvasSize = UDim2.new(0, 0, 0, 0),
                    ScrollBarThickness = 4,
                    ScrollBarImageColor3 = colorScheme.Accent
                })
                create("UIListLayout", {Padding = UDim.new(0, 10), SortOrder = Enum.SortOrder.LayoutOrder})().Parent = col
                columns[i] = col
            end

            -- Заполнить секции
            for _, section in ipairs(self.sections) do
                local col = columns[section.column] or columns[1]
                -- Заголовок секции
                local sectionHeader = create("TextLabel", {
                    Parent = col,
                    BackgroundTransparency = 1,
                    Text = section.name,
                    TextColor3 = colorScheme.Accent,
                    TextSize = 16,
                    Font = Enum.Font.GothamBold,
                    Size = UDim2.new(1, -10, 0, 25)
                })

                -- Контейнер для элементов секции
                local sectionContainer = create("Frame", {
                    Parent = col,
                    BackgroundColor3 = colorScheme.Button,
                    BorderSizePixel = 0,
                    Size = UDim2.new(1, -10, 0, 0),
                    AutomaticSize = Enum.AutomaticSize.Y
                })
                create("UICorner", {CornerRadius = UDim.new(0, 6)})().Parent = sectionContainer
                local containerLayout = create("UIListLayout", {Padding = UDim.new(0, 8), SortOrder = Enum.SortOrder.LayoutOrder})().Parent = sectionContainer
                containerLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
                    sectionContainer.Size = UDim2.new(1, -10, 0, containerLayout.AbsoluteContentSize.Y + 10)
                end)

                -- Добавить элементы
                for _, element in ipairs(section.elements) do
                    if element.type == "toggle" then
                        self:createToggle(element.config, sectionContainer, colorScheme)
                    elseif element.type == "slider" then
                        self:createSlider(element.config, sectionContainer, colorScheme)
                    elseif element.type == "dropdown" then
                        self:createDropdown(element.config, sectionContainer, colorScheme)
                    elseif element.type == "button" then
                        self:createButton(element.config, sectionContainer, colorScheme)
                    end
                end
            end
        end

        function subtab:createToggle(config, parent, colors)
            local frame = create("Frame", {
                Parent = parent,
                BackgroundTransparency = 1,
                Size = UDim2.new(1, -10, 0, 30),
                AutomaticSize = Enum.AutomaticSize.None
            })

            local label = create("TextLabel", {
                Parent = frame,
                BackgroundTransparency = 1,
                Text = config.name,
                TextColor3 = colors.Text,
                TextSize = 14,
                Font = Enum.Font.Gotham,
                TextXAlignment = Enum.TextXAlignment.Left,
                Size = UDim2.new(1, -60, 1, 0)
            })

            local toggleBg = create("Frame", {
                Parent = frame,
                BackgroundColor3 = colors.ToggleOff,
                Position = UDim2.new(1, -50, 0.5, -10),
                Size = UDim2.new(0, 40, 0, 20)
            })
            create("UICorner", {CornerRadius = UDim.new(1, 0)})().Parent = toggleBg

            local toggleCircle = create("Frame", {
                Parent = toggleBg,
                BackgroundColor3 = colors.Text,
                Position = UDim2.new(0, 2, 0.5, -8),
                Size = UDim2.new(0, 16, 0, 16)
            })
            create("UICorner", {CornerRadius = UDim.new(1, 0)})().Parent = toggleCircle

            local enabled = config.default or false
            if enabled then
                toggleBg.BackgroundColor3 = colors.ToggleOn
                toggleCircle.Position = UDim2.new(1, -18, 0.5, -8)
            end

            local function setState(state)
                enabled = state
                if enabled then
                    tween(toggleBg, {BackgroundColor3 = colors.ToggleOn}, 0.2)
                    tween(toggleCircle, {Position = UDim2.new(1, -18, 0.5, -8)}, 0.2)
                else
                    tween(toggleBg, {BackgroundColor3 = colors.ToggleOff}, 0.2)
                    tween(toggleCircle, {Position = UDim2.new(0, 2, 0.5, -8)}, 0.2)
                end
                if config.callback then
                    config.callback(enabled)
                end
            end

            toggleBg.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then
                    setState(not enabled)
                end
            end)
        end

        function subtab:createSlider(config, parent, colors)
            local frame = create("Frame", {
                Parent = parent,
                BackgroundTransparency = 1,
                Size = UDim2.new(1, -10, 0, 40),
                AutomaticSize = Enum.AutomaticSize.None
            })

            local label = create("TextLabel", {
                Parent = frame,
                BackgroundTransparency = 1,

            self.expanded = false
            DropdownMenu:TweenSize(UDim2.new(1, 0, 0, 0), "In", "Quad", 0.1, true)
        end)

        panel.seperators[panel.currentSeperator][title] = function(t) self.selected = t; populateOptions(); renderText(); callback(t) end
        return {
            setOptions = function(opts) self.options = opts; populateOptions(); renderText() end,
            setSelected = function(t) self.selected = t; populateOptions(); renderText(); callback(t) end,
            getSelected = function() return self.selected end,
            setDropdownExpanded = function(exp) self.expanded = exp; if exp then local layout = DropdownMenu:FindFirstChildOfClass("UIListLayout"); DropdownMenu:TweenSize(UDim2.new(1,0,0,layout and layout.AbsoluteContentSize.Y or 0), "Out", "Quad", 0.15, true) else DropdownMenu:TweenSize(UDim2.new(1,0,0,0), "In", "Quad", 0.1, true) end end,

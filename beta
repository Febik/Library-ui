            self.expanded = false
            DropdownMenu:TweenSize(UDim2.new(1, 0, 0, 0), "In", "Quad", 0.1, true)
        end)

        local function setSelected(index)
            selectedIndex = index
            if self.options[index] then
                DropdownBox:FindFirstChildOfClass("TextLabel").Text = self.options[index]
                value[title] = index
                callback(index, self.options[index])
            end
        end

        panel.seperators[panel.currentSeperator][title] = setSelected
        return {
            setOptions = function(newOptions)
                self.options = newOptions
                populateOptions()
            end,
            setSelected = setSelected,
            getSelected = function() return selectedIndex, self.options[selectedIndex] end,
            setDropdownExpanded = function(expanded)
                self.expanded = expanded
                if expanded then updateMenuHeight() else DropdownMenu:TweenSize(UDim2.new(1,0,0,0), "In", "Quad", 0.1, true) end
            end,
            callback = callback
        }
    end


--//Utils
local util = {} do
    function util.new(type, options, children)
        local instance = Instance.new(type)
        
        if instance:IsA("GuiObject") then 
            instance.BorderSizePixel = 0 
            -- Добавляем скругление только для видимых объектов (не прозрачных полностью)
            if options and options.BackgroundTransparency and options.BackgroundTransparency < 1 and options.CornerRadius == nil then
                local corner = Instance.new("UICorner")
                corner.CornerRadius = UDim.new(0, 4)
                corner.Parent = instance
            elseif options and (options.BackgroundTransparency == nil or options.BackgroundTransparency < 1) and options.CornerRadius == nil then
                local corner = Instance.new("UICorner")
                corner.CornerRadius = UDim.new(0, 4)
                corner.Parent = instance
            end
        end

        if instance:IsA("TextLabel") then
            instance.TextXAlignment = Enum.TextXAlignment.Left
            instance.TextYAlignment = Enum.TextYAlignment.Top
        end

        if instance:IsA("TextButton") or instance:IsA("ImageButton") then
            instance.AutoButtonColor = false
            if instance:IsA("TextButton") then instance.Text = "" end
        end
        
        for i,v in pairs(options) do
            instance[i] = v
        end

        if not children then return instance end

        local toReturn = {instance}
        for i,v in pairs(children) do
            v.Parent = instance
            table.insert(toReturn, v)
        end
        return unpack(toReturn)
    end

    function util.children(parent, children)
        local toReturn = {}
        for _,child in pairs(children) do
            child.Parent = parent
            table.insert(toReturn, child)
        end
        return unpack(toReturn)
    end

    function util.tween(instance, properties, duration, style)
        if not instance:IsA("GuiObject") then return end  -- Исправление ошибки: не анимировать UICorner и пр.
        style = style or Enum.EasingStyle.Quad
        TweenService:Create(instance, TweenInfo.new(duration, style, Enum.EasingDirection.Out), properties):Play()
    end

    function util.addShadow(instance, size, transparency)
        local corner = Instance.new("UICorner")
        corner.CornerRadius = UDim.new(0, 8)
        corner.Parent = instance
        local stroke = Instance.new("UIStroke")
        stroke.Color = Color3.fromRGB(0, 0, 0)
        stroke.Transparency = 0.5
        stroke.Thickness = 1
        stroke.Parent = instance
    end
end


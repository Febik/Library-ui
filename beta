                TextXAlignment = Enum.TextXAlignment.Left,
            })
        })

        local optionButtons = {}
        local selectedIndex = data.default or 1

        local function updateMenuHeight()
            local layout = DropdownMenu:FindFirstChildOfClass("UIListLayout")
            if not layout then return end
            local height = layout.AbsoluteContentSize.Y
            DropdownMenu:TweenSize(UDim2.new(1, 0, 0, height), "Out", "Quad", 0.15, true)
        end

        local function populateOptions()
            for _, btn in pairs(optionButtons) do btn:Destroy() end
            optionButtons = {}
            for i, optText in ipairs(self.options) do
                local btn = DropdownItemTemplate:Clone()
                btn.LayoutOrder = i
                btn:FindFirstChildOfClass("TextLabel").Text = optText
                btn.Parent = DropdownMenu
                btn.MouseButton1Click:Connect(function()
                    selectedIndex = i
                    DropdownBox:FindFirstChildOfClass("TextLabel").Text = optText
                    self.expanded = false
                    updateMenuHeight()
                    value[title] = i
                    callback(i, optText)
                end)
                btn.MouseEnter:Connect(function()
                    util.tween(btn, { BackgroundColor3 = theme.Accent, BackgroundTransparency = 0.1 }, 0.1)
                end)
                btn.MouseLeave:Connect(function()
                    util.tween(btn, { BackgroundColor3 = theme.DropdownBg, BackgroundTransparency = 0.3 }, 0.1)
                end)
                table.insert(optionButtons, btn)
            end
            if self.options[selectedIndex] then
                DropdownBox:FindFirstChildOfClass("TextLabel").Text = self.options[selectedIndex]
            end
            updateMenuHeight()
        end

        populateOptions()

        Container.MouseButton1Down:Connect(function()
            self.expanded = not self.expanded
            if self.expanded then
                updateMenuHeight()
            else
                DropdownMenu:TweenSize(UDim2.new(1, 0, 0, 0), "In", "Quad", 0.1, true)
            end

            Position = UDim2.new(0, 26, 0, -1),
            TextYAlignment = Enum.TextYAlignment.Center,
            Name = "CheckboxText"
        })

        local function render(override)
            Checkmark.Visible = self.checked
            value[text] = self.checked
            if not override then callback(self.checked) end
        end
        render(true)

        Container.MouseButton1Down:Connect(function()
            self.checked = not self.checked
            render()
        end)
        Container.MouseEnter:Connect(function()
            util.tween(CheckboxOutline, { BackgroundColor3 = theme.Accent, BackgroundTransparency = 0.1 }, 0.1)
            panel:SetTip(data.desc or "")

            })

            local valueLabel = create("TextLabel", {
                Parent = frame,
                BackgroundTransparency = 1,
                Text = tostring(config.default or 0),
                TextColor3 = colors.Accent,
                TextSize = 14,
                Font = Enum.Font.Gotham,
                TextXAlignment = Enum.TextXAlignment.Right,
                Position = UDim2.new(1, -50, 0, 0),
                Size = UDim2.new(0, 50, 0, 20)
            })

            local sliderBg = create("Frame", {
                Parent = frame,
                BackgroundColor3 = colors.SliderBackground,
                Position = UDim2.new(0, 0, 0, 25),
                Size = UDim2.new(1, 0, 0, 6)
            })
            create("UICorner", {CornerRadius = UDim.new(1, 0)})().Parent = sliderBg

            local sliderFill = create("Frame", {
                Parent = sliderBg,
                BackgroundColor3 = colors.SliderFill,
                Size = UDim2.new((config.default - config.min) / (config.max - config.min), 0, 1, 0)
            })
            create("UICorner", {CornerRadius = UDim.new(1, 0)})().Parent = sliderFill

            local sliderButton = create("TextButton", {
                Parent = sliderBg,
                BackgroundTransparency = 1,
                Text = "",
                Size = UDim2.new(1, 0, 1, 0),
                AutoButtonColor = false
            })

            local dragging = false
            local function updateSlider(input)
                local pos = input.Position.X - sliderBg.AbsolutePosition.X
                local percent = math.clamp(pos / sliderBg.AbsoluteSize.X, 0, 1)
                local value = config.min + (config.max - config.min) * percent
                value = math.floor(value * 10) / 10 -- округление до 1 знака
                valueLabel.Text = tostring(value)
                sliderFill.Size = UDim2.new(percent, 0, 1, 0)
                if config.callback then
                    config.callback(value)
                end
            end

            sliderButton.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then
                    dragging = true
                    updateSlider(input)
                end
            end)

            sliderButton.InputEnded:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then
                    dragging = false
                end
            end)

            UserInputService.InputChanged:Connect(function(input)
                if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
                    updateSlider(input)
                end
            end)
        end

        function subtab:createDropdown(config, parent, colors)
            local frame = create("Frame", {
                Parent = parent,
                BackgroundTransparency = 1,
                Size = UDim2.new(1, -10, 0, 30),
                AutomaticSize = Enum.AutomaticSize.None
            })

            local label = create("TextLabel", {
                Parent = frame,
                BackgroundTransparency = 1,
                Text = config.name,
                TextColor3 = colors.Text,
                TextSize = 14,
                Font = Enum.Font.Gotham,
                TextXAlignment = Enum.TextXAlignment.Left,
                Size = UDim2.new(0.5, 0, 1, 0)
            })

            local dropdownBtn = create("TextButton", {
                Parent = frame,
                BackgroundColor3 = colors.Dropdown,
                Text = config.default or config.options[1],
                TextColor3 = colors.Text,
                TextSize = 14,
                Font = Enum.Font.Gotham,
                Position = UDim2.new(0.5, 5, 0, 0),
                Size = UDim2.new(0.5, -5, 1, 0),
                AutoButtonColor = false
            })
            create("UICorner", {CornerRadius = UDim.new(0, 4)})().Parent = dropdownBtn

            local expanded = false
            local dropdownList = nil

            local function closeList()
                if dropdownList then
                    dropdownList:Destroy()
                    dropdownList = nil
                    expanded = false
                end
            end

            dropdownBtn.MouseButton1Click:Connect(function()
                if expanded then
                    closeList()
                else
                    dropdownList = create("ScrollingFrame", {
                        Parent = frame,
                        BackgroundColor3 = colors.Dropdown,
                        BorderSizePixel = 0,
                        Position = UDim2.new(0.5, 5, 1, 5),
                        Size = UDim2.new(0.5, -5, 0, 100),
                        CanvasSize = UDim2.new(0, 0, 0, 0),
                        ScrollBarThickness = 4,
                        ScrollBarImageColor3 = colors.Accent,
                        ZIndex = 10
                    })
                    create("UICorner", {CornerRadius = UDim.new(0, 4)})().Parent = dropdownList
                    local listLayout = create("UIListLayout", {Padding = UDim.new(0, 2), SortOrder = Enum.SortOrder.LayoutOrder})().Parent = dropdownList
                    listLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
                        dropdownList.CanvasSize = UDim2.new(0, 0, 0, listLayout.AbsoluteContentSize.Y)
                    end)

                    for _, opt in ipairs(config.options) do
                        local optBtn = create("TextButton", {
                            Parent = dropdownList,
                            BackgroundColor3 = colors.Dropdown,
                            Text = opt,
                            TextColor3 = colors.Text,
                            TextSize = 14,
                            Font = Enum.Font.Gotham,
                            Size = UDim2.new(1, 0, 0, 25),
                            AutoButtonColor = false
                        })
                        create("UICorner", {CornerRadius = UDim.new(0, 4)})().Parent = optBtn

                        optBtn.MouseEnter:Connect(function()
                            tween(optBtn, {BackgroundColor3 = colors.DropdownHover}, 0.2)
                        end)
                        optBtn.MouseLeave:Connect(function()
                            tween(optBtn, {BackgroundColor3 = colors.Dropdown}, 0.2)
                        end)

                        optBtn.MouseButton1Click:Connect(function()
                            dropdownBtn.Text = opt
                            if config.callback then
                                config.callback(opt)
                            end
                            closeList()
                        end)
                    end
                    expanded = true
                end
            end)

            -- Закрывать список при клике вне
            UserInputService.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then
                    if dropdownList and not dropdownList:IsDescendantOf(gui) then
                        closeList()
                    end
                end
            end)
        end

        function subtab:createButton(config, parent, colors)
            local btn = create("TextButton", {
                Parent = parent,
                BackgroundColor3 = colors.Button,
                Text = config.name,
                TextColor3 = colors.Text,
                TextSize = 14,
                Font = Enum.Font.Gotham,
                Size = UDim2.new(1, -10, 0, 30),
                AutoButtonColor = false
            })
            create("UICorner", {CornerRadius = UDim.new(0, 4)})().Parent = btn

            btn.MouseEnter:Connect(function()
                tween(btn, {BackgroundColor3 = colors.ButtonHover}, 0.2)
            end)
            btn.MouseLeave:Connect(function()
                tween(btn, {BackgroundColor3 = colors.Button}, 0.2)
            end)

            btn.MouseButton1Click:Connect(function()
                if config.callback then
                    config.callback()
                end
            end)
        end

        table.insert(tab.subtabs, subtab)
        return subtab
    end

    -- Публичные методы окна
    local window = {
        tabs = tabs,
        CreateTab = function(self, name)
            local tab = createTab(name)
            table.insert(tabs, tab)
            return tab
        end,
        CreateSubtab = function(self, tab, name)
            return createSubtab(tab, name)
        end
    }

    -- Выбрать первый таб по умолчанию
    task.wait()
    if #tabs > 0 then
        tabs[1].buttons[1].MouseButton1Click:Fire()
    end

    -- Перетаскивание окна
    local dragging = false
    local dragOffset = Vector2.new()
    titleBar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            dragOffset = Vector2.new(mouse.X - mainFrame.AbsolutePosition.X, mouse.Y - mainFrame.AbsolutePosition.Y)
        end
    end)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            mainFrame.Position = UDim2.new(0, mouse.X - dragOffset.X, 0, mouse.Y - dragOffset.Y)
        end
    end)

    return window
end

return NeverloseUI

    -- Функция для обновления подтабов
    local function updateSubtabList(tab)
        -- Очистить список подтабов
        for _, btn in ipairs(subtabButtons) do
            btn:Destroy()
        end
        subtabButtons = {}

        if not tab then return end

        -- Создать кнопки для каждого подтаба
        for _, subtab in ipairs(tab.subtabs) do
            local btn = create("TextButton", {
                Parent = subtabList,
                BackgroundColor3 = colorScheme.Button,
                Text = subtab.name,
                TextColor3 = colorScheme.Text,
                TextSize = 14,
                Font = Enum.Font.Gotham,
                Size = UDim2.new(1, -10, 0, 30),
                AutoButtonColor = false
            })
            create("UICorner", {CornerRadius = UDim.new(0, 4)})().Parent = btn

            -- Анимация наведения
            btn.MouseEnter:Connect(function()
                tween(btn, {BackgroundColor3 = colorScheme.ButtonHover}, 0.2)
            end)
            btn.MouseLeave:Connect(function()
                if activeSubtab ~= subtab then
                    tween(btn, {BackgroundColor3 = colorScheme.Button}, 0.2)
                end
            end)

            btn.MouseButton1Click:Connect(function()
                if activeSubtab then
                    -- Сбросить цвет предыдущего активного подтаба
                    for _, b in ipairs(subtabButtons) do
                        if b.Subtab == activeSubtab then
                            tween(b, {BackgroundColor3 = colorScheme.Button}, 0.2)
                        end
                    end
                end
                activeSubtab = subtab
                tween(btn, {BackgroundColor3 = colorScheme.Accent}, 0.2)
                subtab:Render(columnsContainer)
            end)

            btn.Subtab = subtab
            table.insert(subtabButtons, btn)
        end

        -- Выбрать первый подтаб по умолчанию
        if #subtabButtons > 0 then
            subtabButtons[1].MouseButton1Click:Fire()
        end
    end


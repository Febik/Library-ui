                Position = UDim2.new(1, -22, 0.5, -8),
                BackgroundTransparency = 1,
                ImageColor3 = theme.SubTextColor,
            })
        })

        local DropdownMenu = util.new("Frame", {
            Parent = DropdownBox,
            Size = UDim2.new(1, 0, 0, 0),
            Position = UDim2.new(0, 0, 1, 2),
            BackgroundColor3 = theme.DropdownBg,
            BackgroundTransparency = 0.05,
            ClipsDescendants = true,
            ZIndex = 60,
        }, {
            util.new("UICorner", { CornerRadius = UDim.new(0, 8) }),
            util.new("UIListLayout", {
                SortOrder = Enum.SortOrder.LayoutOrder,
                Padding = UDim.new(0, 0),
                HorizontalAlignment = Enum.HorizontalAlignment.Center,
            })
        })

        local function renderText()
            local text = ""
            for _, idx in pairs(self.selected) do
                if self.options[idx] then
                    text = text .. self.options[idx] .. ", "
                end
            end
            DropdownBox:FindFirstChildOfClass("TextLabel").Text = text:sub(1, -3)
            value[title] = self.selected
        end

        local function populateOptions()
            for _, obj in pairs(self.optionObjects) do obj:Destroy() end
            self.optionObjects = {}
            for i, optText in ipairs(self.options) do
                local selected = table.find(self.selected, i) ~= nil
                local btn = util.new("TextButton", {
                    Parent = DropdownMenu,
                    LayoutOrder = i,
                    Size = UDim2.new(1, 0, 0, 28),
                    BackgroundColor3 = theme.DropdownBg,
                    BackgroundTransparency = 0.3,
                    ZIndex = 61,
                }, {
                    util.new("UICorner", { CornerRadius = UDim.new(0, 6) }),
                    util.new("TextLabel", {
                        Text = optText,
                        TextColor3 = selected and theme.Accent or theme.SubTextColor,
                        TextSize = 12,
                        Font = Enum.Font.Gotham,
                        Size = UDim2.new(1, -10, 1, 0),
                        Position = UDim2.new(0, 8, 0, 0),
                        BackgroundTransparency = 1,
                        TextYAlignment = Enum.TextYAlignment.Center,
                    })
                })
                btn.MouseButton1Click:Connect(function()
                    local found = table.find(self.selected, i)
                    if found then
                        table.remove(self.selected, found)
                    else
                        table.insert(self.selected, i)
                    end
                    populateOptions()
                    renderText()
                    callback(self.selected)
                end)
                table.insert(self.optionObjects, btn)
            end
            local layout = DropdownMenu:FindFirstChildOfClass("UIListLayout")
            if layout then
                local height = layout.AbsoluteContentSize.Y
                if self.expanded then
                    DropdownMenu:TweenSize(UDim2.new(1, 0, 0, height), "Out", "Quad", 0.15, true)
                else
                    DropdownMenu.Size = UDim2.new(1, 0, 0, 0)
                end
            end
        end

        populateOptions()
        renderText()

        Container.MouseButton1Down:Connect(function()
            self.expanded = not self.expanded
            if self.expanded then
                local layout = DropdownMenu:FindFirstChildOfClass("UIListLayout")
                local height = layout and layout.AbsoluteContentSize.Y or 0
                DropdownMenu:TweenSize(UDim2.new(1, 0, 0, height), "Out", "Quad", 0.15, true)
            else
                DropdownMenu:TweenSize(UDim2.new(1, 0, 0, 0), "In", "Quad", 0.1, true)
            end
        end)

        Container.MouseEnter:Connect(function()
            util.tween(DropdownBox, { BackgroundColor3 = theme.Accent, BackgroundTransparency = 0.1 }, 0.1)
            panel:SetTip(data.desc or "")
        end)
        Container.MouseLeave:Connect(function()
            if not self.expanded then
                util.tween(DropdownBox, { BackgroundColor3 = theme.InteractableOutline, BackgroundTransparency = 0.3 }, 0.1)
            end
            panel:SetTip("")
        end)


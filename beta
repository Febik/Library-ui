            Size = UDim2.new(0,0,0,20),
            Position = UDim2.new(0, 0, 0, -2),
            TextYAlignment = Enum.TextYAlignment.Center,
        })

        -- Значение (TextBox)
        local ValueboxOutline = util.new("Frame", {
            Parent = Container,
            Size = UDim2.new(0, 45, 0, 22),
            Position = UDim2.new(1, -45, 0, -2),
            BackgroundColor3 = theme.InteractableOutline,
            BackgroundTransparency = 0.3,
            Name = "ValueboxOutline"
        }, {
            util.new("UICorner", { CornerRadius = UDim.new(0, 6) }),
            util.new("TextBox", {
                Text = "12.5",
                TextSize = 12,
                TextColor3 = theme.SubTextColor,
                Size = UDim2.new(1, -4, 1, -4),
                Position = UDim2.new(0, 2, 0, 2),
                BackgroundColor3 = theme.InteractableBackground,
                BackgroundTransparency = 0.9,
                Name = "ValueboxInside"
            })
        })

        -- Трек слайдера
        local SliderTrack = util.new("Frame", {
            Parent = Container,
            Size = UDim2.new(1, -10, 0, 4),
            Position = UDim2.new(0, 5, 0, 28),
            BackgroundColor3 = theme.SliderTrack,
            BackgroundTransparency = 0.5,
            Name = "SliderTrack"
        }, {
            util.new("UICorner", { CornerRadius = UDim.new(1, 0) }),
            util.new("Frame", {
                Size = UDim2.new(0, 0, 1, 0),
                BackgroundColor3 = theme.SliderFill,
                Name = "SliderFill"
            })
        })

        -- Круглый ползунок
        local Knob = util.new("Frame", {
            Parent = Container,
            Size = UDim2.new(0, 12, 0, 12),
            Position = UDim2.new(0, 0, 0, 24),
            BackgroundColor3 = theme.Accent,
            Name = "Knob"
        }, {
            util.new("UICorner", { CornerRadius = UDim.new(1, 0) }),
            util.new("UIStroke", { Color = Color3.fromRGB(255,255,255), Transparency = 0.5, Thickness = 1 })
        })

        local function renderFromPercent(percent, override)
            percent = math.clamp(percent, 0, 1)
            local min = self.values.min
            local max = self.values.max
            local actualValue = round(percent * (max - min) + min)
            ValueboxOutline.ValueboxInside.Text = tostring(actualValue)
            local trackWidth = SliderTrack.AbsoluteSize.X
            local knobPos = percent * (trackWidth - Knob.AbsoluteSize.X)
            Knob.Position = UDim2.new(0, knobPos, 0, 24)
            SliderTrack.SliderFill.Size = UDim2.new(percent, 0, 1, 0)
            value[text] = actualValue
            if not override then callback(actualValue) end
        end

        local function renderFromValue(val, override)
            local min = self.values.min
            local max = self.values.max
            renderFromPercent((val - min) / (max - min), override)
        end

        local function renderFromMouse()
            local mouseX = input:GetMouseLocation().X
            local trackLeft = SliderTrack.AbsolutePosition.X
            local trackRight = trackLeft + SliderTrack.AbsoluteSize.X
            local percent = (mouseX - trackLeft) / (trackRight - trackLeft)
            renderFromPercent(percent)
        end

        renderFromValue(self.values.default, true)

        local dragging = false
        Container.InputBegan:Connect(function(inp, gpe)
            if inp.UserInputType == Enum.UserInputType.MouseButton1 and not gpe then
                dragging = true
                renderFromMouse()
            end
        end)
        Container.InputEnded:Connect(function(inp, gpe)
            if inp.UserInputType == Enum.UserInputType.MouseButton1 and not gpe then
                dragging = false
            end
        end)
        RunService.RenderStepped:Connect(function()
            if dragging then renderFromMouse() end
        end)

        -- Обработка TextBox
        local isFocused = false
        local textBox = ValueboxOutline.ValueboxInside
        textBox.Focused:Connect(function()
            isFocused = true
            util.tween(ValueboxOutline, { BackgroundColor3 = theme.Accent, BackgroundTransparency = 0.1 }, 0.1)
        end)
        textBox.FocusLost:Connect(function()
            local val = tonumber(textBox.Text)
            if val then renderFromValue(val) end
            isFocused = false
            util.tween(ValueboxOutline, { BackgroundColor3 = theme.InteractableOutline, BackgroundTransparency = 0.3 }, 0.1)
        end)

        Container.MouseEnter:Connect(function()
            panel:SetTip(data.desc or "")
        end)
        Container.MouseLeave:Connect(function()
            panel:SetTip("")
        end)

        panel.seperators[panel.currentSeperator][text] = renderFromValue
        return {
            setPercent = renderFromPercent,
            setValue = renderFromValue,
            getValue = function() return value[text] end,
            callback = callback
        }
    end

